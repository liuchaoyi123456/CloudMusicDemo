<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 动态渐变背景 -->
    <com.example.cloudmusicdemo.core.ui.GradientBackgroundView
        android:id="@+id/gradientBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- 内容区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- 顶部：歌名和歌手 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tvPlayerSongName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="歌曲名称"
                android:textSize="20sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvPlayerArtist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="歌手"
                android:textSize="13sp"
                android:textColor="#AAAAAA"
                android:layout_marginTop="6dp" />
        </LinearLayout>

        <!-- 中间：封面照片（圆形） -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center">

            <!-- 外圈光晕效果 -->
            <View
                android:layout_width="260dp"
                android:layout_height="260dp"
                android:layout_gravity="center"
                android:layout_marginBottom="40dp"
                android:background="@drawable/bg_cover_glow" />

            <!-- 圆形封面 -->
            <ImageView
                android:id="@+id/ivPlayerCover"
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:layout_gravity="center"
                android:layout_marginBottom="40dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_music"
                android:background="@drawable/bg_cover_circle"
                android:clipToOutline="true" />

        </FrameLayout>

        <!-- 歌词区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp">

            <!-- 上一句歌词 -->
            <TextView
                android:id="@+id/tvLyricPrevious"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="14sp"
                android:textColor="#888888"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- 当前歌词（高亮） -->
            <TextView
                android:id="@+id/tvLyricCurrent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="暂无歌词"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:textStyle="bold" />

            <!-- 下一句歌词 -->
            <TextView
                android:id="@+id/tvLyricNext"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="14sp"
                android:textColor="#888888"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

        <!-- 底部：进度条和控制按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">

            <!-- 进度条 -->
            <SeekBar
                android:id="@+id/seekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" />

            <!-- 时间显示 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tvCurrentTime"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="00:00"
                    android:textSize="12sp"
                    android:textColor="#999999" />

                <TextView
                    android:id="@+id/tvTotalTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textSize="12sp"
                    android:textColor="#999999" />
            </LinearLayout>

            <!-- 播放控制按钮 -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- 播放模式按钮（左侧） -->
                <ImageView
                    android:id="@+id/ivPlayerPlayMode"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_play_mode_sequence"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:layout_gravity="center_vertical|start" />

                <!-- 中间的播放控制按钮组 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_gravity="center">

                    <ImageView
                        android:id="@+id/ivPlayerPrev"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_skip_previous"
                        android:padding="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackgroundBorderless" />

                    <ImageView
                        android:id="@+id/ivPlayerPlayPause"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:src="@android:drawable/ic_media_play"
                        android:padding="8dp"
                        android:layout_marginStart="32dp"
                        android:layout_marginEnd="32dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackgroundBorderless" />

                    <ImageView
                        android:id="@+id/ivPlayerNext"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_skip_next"
                        android:padding="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackgroundBorderless" />

                </LinearLayout>

                <!-- 播放列表按钮（右侧） -->
                <ImageView
                    android:id="@+id/ivPlayerPlaylist"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_playlist_play"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:layout_gravity="center_vertical|end" />

            </FrameLayout>
        </LinearLayout>

    </LinearLayout>

</FrameLayout>
