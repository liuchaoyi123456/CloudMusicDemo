<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 动态渐变背景 -->
    <com.example.cloudmusicdemo.core.ui.GradientBackgroundView
        android:id="@+id/gradientBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- 内容区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <ImageView
            android:id="@+id/ivPlayerCover"
            android:layout_width="280dp"
            android:layout_height="280dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_music"
            android:layout_marginBottom="24dp" />

        <!-- 歌词显示区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="16dp">

            <!-- 上一句歌词 -->
            <TextView
                android:id="@+id/tvLyricPrevious"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="14sp"
                android:textColor="#999999"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- 当前歌词（高亮） -->
            <TextView
                android:id="@+id/tvLyricCurrent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="暂无歌词"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="4dp"
                android:textStyle="bold" />

            <!-- 下一句歌词 -->
            <TextView
                android:id="@+id/tvLyricNext"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="14sp"
                android:textColor="#999999"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvPlayerSongName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="歌曲名称"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvPlayerArtist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="歌手"
            android:textSize="16sp"
            android:textColor="#999999"
            android:gravity="center"
            android:layout_marginBottom="32dp" />

        <!-- 进度条 -->
        <SeekBar
            android:id="@+id/seekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="32dp">

            <TextView
                android:id="@+id/tvCurrentTime"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="00:00"
                android:textSize="12sp"
                android:textColor="#999999" />

            <TextView
                android:id="@+id/tvTotalTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textSize="12sp"
                android:textColor="#999999" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_gravity="center">

            <ImageView
                android:id="@+id/ivPlayerPrev"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/ic_skip_previous"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <ImageView
                android:id="@+id/ivPlayerPlayPause"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:src="@android:drawable/ic_media_play"
                android:padding="8dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <ImageView
                android:id="@+id/ivPlayerNext"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/ic_skip_next"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless" />
        </LinearLayout>

    </LinearLayout>

</FrameLayout>
